# Flask Configuration
FLASK_ENV=development
SECRET_KEY=your-super-secret-key-change-in-production
PORT=5000

# Zerodha OAuth Configuration
# Get these from https://kite.trade/apps (Create New App)
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here
KITE_REDIRECT_URL=http://localhost:5000/callback

# For production on Render:
# KITE_REDIRECT_URL=https://your-app.onrender.com/callback

# Frontend URL (where to redirect after OAuth)
FRONTEND_URL=http://localhost:3000
# FRONTEND_URL=https://your-frontend.com (for production)

# Telegram Configuration (Optional)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_USER_ID=your_user_id_here

# Database Configuration
DATABASE_URL=sqlite:///paper_trades.db

# JWT Settings
JWT_EXPIRY_HOURS=24